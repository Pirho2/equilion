generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(uuid())
  email     String       @unique
  password  String
  createdAt DateTime     @default(now())
  entries   DailyEntry[]
}

model DailyEntry {
  id        String     @id @default(uuid())
  mood      Int
  note      String
  date      DateTime   @default(now())
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  emotions  Emotion[]  @relation("EntryEmotions")
}

model Emotion {
  id      String        @id @default(uuid())
  name    String
  entries DailyEntry[]  @relation("EntryEmotions")
}